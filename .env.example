# PostgreSQL
DB_PASSWORD=your_very_secure_db_password

# JWT
JWT_SECRET=your_very_long_random_jwt_secret_min_64_chars

# Frontend URL (for CORS)
FRONTEND_URL=https://cbfm.fisheries.gov.vu

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-southeast-2
AWS_S3_BUCKET=cbfm-vanuatu-datasets

# Admin account (created on first startup)
ADMIN_EMAIL=admin@fisheries.gov.vu
ADMIN_PASSWORD=Admin@Fisheries2024!
