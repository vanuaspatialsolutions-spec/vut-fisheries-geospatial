rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Authenticated users can read any file
    match /{allPaths=**} {
      allow read: if request.auth != null;
    }
    // Users can upload to their own datasets folder
    match /datasets/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Users can upload/delete their own files (My Files page)
    match /userFiles/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    // Any authenticated user can upload message attachments
    match /messages/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
