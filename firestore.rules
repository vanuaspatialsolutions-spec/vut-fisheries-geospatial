rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the requesting user an admin? ────────────────────────────
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users collection ────────────────────────────────────────────────────
    match /users/{userId} {
      allow get:  if request.auth != null;
      allow list: if request.auth != null;          // needed for user picker in Messages
      allow create: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Surveys ─────────────────────────────────────────────────────────────
    match /surveys/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Marine areas ────────────────────────────────────────────────────────
    match /marine_areas/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Monitoring records ──────────────────────────────────────────────────
    match /monitoring/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Datasets ────────────────────────────────────────────────────────────
    match /datasets/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── User Files (My Files page) ───────────────────────────────────────────
    match /userFiles/{userId}/{document=**} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // ── Threads (messaging) ──────────────────────────────────────────────────
    match /threads/{threadId} {
      // Allow get even when doc is absent so getOrCreateThread can check existence first.
      allow get: if request.auth != null &&
        (resource == null || request.auth.uid in resource.data.participants);
      // List is restricted to threads the user participates in.
      allow list: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      // Any authenticated user can create a thread they are a member of.
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;
      // Participants can update metadata (lastMessage, unread, deletedFor, etc.)
      // but cannot change the participants list or isGroup flag.
      allow update: if request.auth != null &&
        request.auth.uid in resource.data.participants &&
        !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['participants', 'isGroup', 'createdAt']);

      // Messages inside a thread: readable/writable by participants only.
      match /messages/{msgId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants;
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants &&
          request.resource.data.senderId == request.auth.uid;
        // Soft-delete: only the original sender may clear their message.
        allow update: if request.auth != null &&
          resource.data.senderId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['deleted', 'text', 'attachment']);
      }
    }

    // ── Notifications ────────────────────────────────────────────────────────
    // A user can read and update (mark read) their own notifications.
    // Any authenticated user can create a notification for another user (when sending a message).
    match /notifications/{userId}/items/{notifId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // ── Schedule events ──────────────────────────────────────────────────────
    // All authenticated users can read org-wide calendar events.
    // Only the creator (or an admin) can update or delete their own events.
    match /scheduleEvents/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Trip plans ───────────────────────────────────────────────────────────
    // All authenticated users can view trips (shared org-wide).
    // Only the creator (or an admin) can create, edit, or delete trips.
    match /trips/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null &&
        (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
