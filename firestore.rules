rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the requesting user an admin? ────────────────────────────
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users collection ────────────────────────────────────────────────────
    match /users/{userId} {
      allow get:  if request.auth != null;
      allow list: if request.auth != null;          // needed for user picker in Messages
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if (request.auth != null && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Surveys ─────────────────────────────────────────────────────────────
    match /surveys/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Marine areas ────────────────────────────────────────────────────────
    match /marine_areas/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Monitoring records ──────────────────────────────────────────────────
    match /monitoring/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── Datasets ────────────────────────────────────────────────────────────
    match /datasets/{docId} {
      allow read, write: if request.auth != null;
    }

    // ── User Files (My Files page) ───────────────────────────────────────────
    match /userFiles/{userId}/{subcollection}/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Threads (messaging) ──────────────────────────────────────────────────
    // A participant can read and update the thread document.
    // Any authenticated user can create a thread (they add themselves as participant).
    match /threads/{threadId} {
      allow read, update: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      allow create: if request.auth != null &&
        request.auth.uid in request.resource.data.participants;

      // Messages inside a thread: readable/writable by thread participants only.
      match /messages/{msgId} {
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants;
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/threads/$(threadId)).data.participants &&
          request.resource.data.senderId == request.auth.uid;
      }
    }

    // ── Notifications ────────────────────────────────────────────────────────
    // A user can read and update (mark read) their own notifications.
    // Any authenticated user can create a notification for another user (when sending a message).
    match /notifications/{userId}/items/{notifId} {
      allow read, update: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }
  }
}
